# Absolute path to the paper directory. It must contain project.json and main.tex.
PAPER_PROJECT_DIR=/absolute/path/to/your-paper

# Optional multi-paper library. Each child directory is a project slug and the
# root must contain index.json with a `projects` array.
PAPER_PROJECTS_DIR=/absolute/path/to/your-project-library

# Local development uses Caddy's localhost certificate. Set a real DNS name only
# after adding authentication in front of the service.
PAPER_DOMAIN=localhost
PAPER_BIND_ADDRESS=127.0.0.1

# Match the owner of CODEX_AUTH_FILE on Linux/macOS (`id -u` and `id -g`).
HOST_UID=1000
HOST_GID=1000
BACKUP_RETENTION=50

# Generate a long random value and keep it out of Git. Caddy injects this value
# server-side; it is never sent to browser JavaScript.
CODEX_BRIDGE_TOKEN=replace-with-a-long-random-value

# Absolute path to your local Codex authentication file. Never copy or commit it.
CODEX_AUTH_FILE=/absolute/path/to/.codex/auth.json

{$PAPER_DOMAIN:localhost} {
    encode zstd gzip
    @client_error {
        path /__client_error
        method POST
        header Content-Type application/json*
    }
    handle @client_error {
        respond 204
    }
    handle /__client_error {
        respond 405
    }

    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }

    @public_brand_asset path /favicon.ico /apple-touch-icon.png /site.webmanifest /assets/favicon-64.png
    handle @public_brand_asset {
        reverse_proxy workspace:8080
    }

    handle {
        request_header -X-Auth-Request-User
        request_header -X-Auth-Request-Email
        request_header -X-Auth-Request-Groups
        request_header -X-Paper-Actor
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Groups
            header_up X-Forwarded-For {http.request.remote.host}
        }
        @project_asset path_regexp project_asset ^/p/([A-Za-z0-9][A-Za-z0-9_-]{0,63})/project/(.*)$
        handle @project_asset {
            rewrite * /projects/{re.project_asset.1}/{re.project_asset.2}
            reverse_proxy workspace:8080
        }
        @project_root path_regexp project_root ^/p/([A-Za-z0-9][A-Za-z0-9_-]{0,63})/?$
        handle @project_root {
            rewrite * /index.html
            reverse_proxy workspace:8080
        }
        handle / {
            rewrite * /hub.html
            reverse_proxy workspace:8080
        }
        @public_thumbnail path_regexp public_thumbnail ^/projects/[A-Za-z0-9][A-Za-z0-9_-]{0,63}/thumbnail\.(?:png|jpe?g|webp)$
        handle @public_thumbnail {
            reverse_proxy workspace:8080
        }
        handle /api/codex {
            reverse_proxy codex-bridge:8790 {
                header_up Authorization "Bearer {$CODEX_BRIDGE_TOKEN}"
                header_up X-Paper-Actor {http.request.header.X-Auth-Request-Email}
            }
        }
        handle_path /api/backups/* {
            reverse_proxy backup:8010 {
                header_up X-Paper-Actor {http.request.header.X-Auth-Request-Email}
            }
        }
        handle_path /api/* {
            reverse_proxy compiler:8000 {
                header_up X-Paper-Actor {http.request.header.X-Auth-Request-Email}
            }
        }
        handle /collab* {
            reverse_proxy collaboration:8765 {
                header_up X-Paper-Actor {http.request.header.X-Auth-Request-Email}
            }
        }
        reverse_proxy workspace:8080
    }

    handle_errors {
        @unauthorized expression `{http.error.status_code} == 401`
        redir @unauthorized /oauth2/start?rd={http.request.uri} 302
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self' wss://{$PAPER_DOMAIN}; font-src 'self' data:; form-action 'self'; frame-ancestors 'none'; frame-src 'self' blob:; img-src 'self' data: blob:; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}

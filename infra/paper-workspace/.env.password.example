# Copy to .env.password. This file must never be committed.
PAPER_ACCESS_PASSWORD=replace-with-your-private-lab-password
# Generate once with: openssl rand -hex 32
PAPER_SESSION_SECRET=replace-with-a-long-random-secret
# 30 days; close the browser or rotate the secret to revoke sessions sooner.
PAPER_SESSION_MAX_AGE=2592000

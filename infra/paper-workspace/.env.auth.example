# Copy this file to .env.auth. Keep it out of Git.
# Create a Google OAuth Web application with this exact callback URL:
# https://YOUR_PAPER_DOMAIN/oauth2/callback

OAUTH2_PROXY_CLIENT_ID=github-oauth-client-id
OAUTH2_PROXY_CLIENT_SECRET=github-oauth-client-secret
# Generate with: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret
OAUTH2_PROXY_REDIRECT_URL=https://YOUR_PAPER_DOMAIN/oauth2/callback

# The allowed Google email addresses are stored one per line in
# .auth/allowed-emails. Keep that file private and do not commit it.

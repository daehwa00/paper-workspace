{$PAPER_DOMAIN:localhost} {
    encode zstd gzip
    @foreign_unsafe {
        method POST PUT PATCH DELETE
        header Origin *
        not header Origin https://{$PAPER_DOMAIN}
    }
    handle @foreign_unsafe {
        respond 403
    }
    @client_error {
        path /__client_error
        method POST
        header Content-Type application/json*
    }
    handle @client_error {
        respond 204
    }
    handle /__client_error {
        respond 405
    }

    handle /_auth/* {
        handle_path /_auth/* {
            reverse_proxy password-gate:8079
        }
    }

    @public_brand_asset path /favicon.ico /apple-touch-icon.png /site.webmanifest /assets/favicon-64.png
    handle @public_brand_asset {
        reverse_proxy workspace:8080
    }

    handle {
        request_header -X-Paper-Actor
        request_header -X-Paper-Client-IP
        forward_auth password-gate:8079 {
            uri /verify
            header_up X-Paper-Client-IP {http.request.remote.host}
        }
        @hub expression `{http.request.uri.path} == "/"`
        handle @hub {
            rewrite * /hub.html
            reverse_proxy workspace:8080
        }
        @project_thumbnail path_regexp project_thumbnail ^/projects/[A-Za-z0-9][A-Za-z0-9_-]{0,63}/thumbnail\.(?:png|jpe?g|webp)$
        handle @project_thumbnail {
            reverse_proxy workspace:8080
        }
        # The ALPHABET catalog entry is an alias to the single default source.
        @default_project_asset path_regexp default_project_asset ^/p/aaai27/project/(.*)$
        handle @default_project_asset {
            rewrite * /project/{re.default_project_asset.1}
            reverse_proxy workspace:8080
        }
        @project_asset path_regexp project_asset ^/p/([A-Za-z0-9][A-Za-z0-9_-]{0,63})/project/(.*)$
        handle @project_asset {
            rewrite * /projects/{re.project_asset.1}/{re.project_asset.2}
            reverse_proxy workspace:8080
        }
        @project_root path_regexp project_root ^/p/([A-Za-z0-9][A-Za-z0-9_-]{0,63})/?$
        handle @project_root {
            rewrite * /index.html
            reverse_proxy workspace:8080
        }
        handle /api/codex {
            reverse_proxy codex-bridge:8790 {
                header_up Authorization "Bearer {$CODEX_BRIDGE_TOKEN}"
                header_up X-Paper-Actor "shared-password-user"
            }
        }
        handle_path /api/backups/* {
            reverse_proxy backup:8010 {
                header_up X-Paper-Actor "shared-password-user"
            }
        }
        handle_path /api/* {
            reverse_proxy compiler:8000 {
                header_up X-Paper-Actor "shared-password-user"
            }
        }
        handle /collab-runtime/* {
            reverse_proxy collaboration:8765 {
                header_up X-Paper-Actor "shared-password-user"
            }
        }
        handle /collab* {
            reverse_proxy collaboration:8765 {
                header_up X-Paper-Actor "shared-password-user"
            }
        }
        reverse_proxy workspace:8080
    }

    handle_errors {
        @unauthorized expression `{http.error.status_code} == 401`
        redir @unauthorized /_auth/login?rd={http.request.uri} 302
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self' wss://{$PAPER_DOMAIN}; font-src 'self' data:; form-action 'self'; frame-ancestors 'none'; frame-src 'self' blob:; img-src 'self' data: blob:; object-src 'none'; script-src 'self' 'sha256-Tx42W/MPQfb1QERV0+646G0lL0n9Pk4i+gHok6qO1LI='; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
